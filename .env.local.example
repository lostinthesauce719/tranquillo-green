# -----------------------------------------------------------
# Convex
# -----------------------------------------------------------
# Your Convex deployment URL. Found in the Convex dashboard or
# created via `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=https://demo-project.convex.cloud

# -----------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------
# Public publishable key (safe for the browser). Found in the
# Clerk dashboard under API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret key (server-only, never expose to the client). Found
# in the Clerk dashboard under API Keys.
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Optional: Override the default Clerk JWT issuer domain.
# Only needed if you use a custom Clerk domain or proxy.
# CLERK_JWT_ISSUER_DOMAIN=https://your-custom-domain.clerk.accounts.dev

# Optional: Name of the Clerk JWT template used for Convex.
# Defaults to "convex" if not set. Create this template in the
# Clerk dashboard under JWT Templates.
# CLERK_CONVEX_JWT_TEMPLATE=convex

# -----------------------------------------------------------
# QuickBooks Online (Intuit)
# -----------------------------------------------------------
# App credentials from https://developer.intuit.com/app/developer/dashboard
# QBO_CLIENT_ID=your_client_id
# QBO_CLIENT_SECRET=your_client_secret
# QBO_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
# QBO_SANDBOX=true

# -----------------------------------------------------------
# OpenAI (if used by the application)
# -----------------------------------------------------------
# OPENAI_API_KEY=***
